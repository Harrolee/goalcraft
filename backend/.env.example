# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/goalcraft

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# VAPI Voice Calls Configuration
# Get your API key from https://dashboard.vapi.ai
VAPI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Phone number ID from VAPI dashboard (not the phone number itself)
VAPI_PHONE_NUMBER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Base URL for webhooks (e.g., https://your-app.com/api/v1)
CALLBACK_BASE_URL=https://your-app.com/api/v1

# Google OAuth Configuration
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxx

# Auth0 Configuration
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://goalcraft.api
